# Postgres connection (docker-compose overrides this with the postgres service host)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/migration_foreman

# GitHub PAT with repo scope — OPTIONAL. Only used by the "Create pull
# request" publishing path (POST /campaign/{id}/finalize); a token can also
# be supplied per-request from the UI ("Connect GitHub"). The default
# "Apply locally" path needs no GitHub authentication at all.
GITHUB_TOKEN=

# GitHub OAuth App for the "Connect GitHub" button (browser web flow) —
# OPTIONAL. Register at github.com -> Settings -> Developer settings ->
# OAuth Apps. The app's "Authorization callback URL" must EXACTLY match
# GITHUB_OAUTH_REDIRECT_URI (protocol, host, port, path) — re-check both
# sides if the demo machine/port/tunnel changes. Unset = the UI falls back
# to the manual token field. Tokens are held in backend memory only (never
# sent to the browser); a backend restart means reconnecting.
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://localhost:8000/github/callback

# --- LLM provider selection ----------------------------------------------
# Which API drives planning + per-unit migration. Leave empty to auto-detect:
# the first of codex (OPENAI_API_KEY) / groq (GROQ_API_KEY) / custom
# (LLM_API_KEY) with a key set wins. Values: codex | groq | <custom name>
LLM_PROVIDER=

# Groq (OpenAI-compatible chat completions)
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-20b
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Any other OpenAI-compatible endpoint, used when LLM_PROVIDER is a custom
# name (e.g. LLM_PROVIDER=ollama, LLM_BASE_URL=http://localhost:11434/v1)
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=

# OpenAI API key for Codex invocations (Responses API). Codex takes priority
# over Groq in auto-detect: set the key and the backend switches to Codex —
# no other change needed.
OPENAI_API_KEY=
CODEX_MODEL=gpt-5-codex

# Set to 1 to run the whole pipeline offline with a deterministic mock
# migration instead of real Codex calls (dev/demo fallback)
MOCK_CODEX=0

FRONTEND_BASE_URL=http://localhost:3000
BACKEND_BASE_URL=http://localhost:8000

# Consumed by the Next.js frontend (browser-side) to reach the backend
NEXT_PUBLIC_BACKEND_BASE_URL=http://localhost:8000
